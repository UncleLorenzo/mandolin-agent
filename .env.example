# Mandolin is model-agnostic. Set a key for whichever brain you want behind it.
# Nothing leaves your machine except the calls you make to your chosen model.

# Default: Anthropic (Claude)
ANTHROPIC_API_KEY=

# Or bring your own OpenAI-compatible endpoint
# OPENAI_API_KEY=

# Ollama needs no key — just `mando model ollama <model>` with Ollama running.
